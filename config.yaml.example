# NetCertGuardian — пример конфигурации
# Скопируйте этот файл в config.yaml и отредактируйте

credentials:
  # Учётная запись с правами локального администратора на всех целевых машинах
  username: "DOMAIN\\Administrator"   # или просто "Administrator" для локальной учётки
  password: "YourPasswordHere"

network:
  # Диапазон для сканирования в формате CIDR. Оставьте пустым для автоопределения подсети.
  scan_range: ""                 # пример: "192.168.1.0/24"
  # IP-адреса, которые нужно исключить из сканирования
  exclude_ips:
    - "192.168.1.1"              # роутер
    - "192.168.1.254"            # шлюз
  # Максимальное количество параллельных подключений для сбора сертификатов
  max_workers: 15
  # Таймаут TCP-подключения при обнаружении (секунды)
  discovery_timeout: 2
  # Таймаут выполнения команды на удалённой машине (секунды)
  collection_timeout: 30

certificates:
  # Хранилище сертификатов Windows. LocalMachine\My — личные сертификаты компьютера.
  store: "LocalMachine\\My"
  # Сертификаты, до истечения которых осталось меньше N дней, считаются "истекающими"
  expiration_threshold_days: 30

paths:
  # Директория для архивных отчётов (создаётся автоматически)
  reports_dir: "./reports"
  # Путь для итоговой HTML-страницы (перезаписывается при каждом запуске)
  html_path: "./cert-status.html"
  # Путь для JSON с данными последнего сканирования
  json_path: "./data/latest-scan.json"
  # Путь для основного лога
  log_path: "./logs/app.log"

rotation:
  # Хранить не более N последних папок с отчётами (0 = без ограничения по количеству)
  max_reports: 30
  # Удалять папки с отчётами старше N дней (0 = без ограничения по возрасту)
  max_age_days: 90
